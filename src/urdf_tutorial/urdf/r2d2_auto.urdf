<robot name="r2d2">

<link name="axis">
  <visual>
    <geometry>
      <cylinder radius="0.01" length="0.5"/>
    </geometry>
  </visual>
</link>

<link name="leg1">
  <visual>
    <geometry>
      <box size="0.2 0.1 0.8"/>
    </geometry>
  </visual>
</link>

<link name="leg2">
  <visual>
    <geometry>
      <box size="0.2 0.1 0.8"/>
    </geometry>
  </visual>
</link>

<link name="body">
  <visual>
    <geometry>
      <cylinder radius="0.2" length="0.6"/>
    </geometry>
  </visual>
</link>

<link name="head">
  <visual>
    <geometry>
      <sphere radius="0.4"/>
    </geometry>
  </visual>
</link>

<link name="rod">
  <visual>
    <geometry>
      <cylinder radius="0.02" length="0.2"/>
    </geometry>
  </visual>
</link>

<link name="box">
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05"/>
    </geometry>
  </visual>
</link>

<!-- joints -->

<joint name="leg1connect" type="fixed">
  <parent link="axis"/>
  <child link="leg1"/>
</joint>

<joint name="leg2connect" type="fixed">
  <parent link="axis"/>
  <child link="leg2"/>
</joint>

<joint name="tilt" type="continuous">
  <parent link="axis"/>
  <child link="body"/>
  <axis xyz="0 1 0"/>
</joint>

<joint name="swivel" type="continuous">
  <parent link="body"/>
  <child link="head"/>
  <axis xyz="0 0 1"/>
</joint>

<joint name="periscope" type="continuous">
  <parent link="head"/>
  <child link="rod"/>
  <axis xyz="0 0 1"/>
</joint>

<joint name="boxconnect" type="fixed">
  <parent link="rod"/>
  <child link="box"/>
</joint>

</robot>