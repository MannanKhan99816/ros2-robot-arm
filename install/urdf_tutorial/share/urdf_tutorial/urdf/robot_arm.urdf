<?xml version="1.0"?>
<robot name="robot_arm">

  <!-- MATERIALS -->
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <!-- BASE -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.3"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- SHOULDER LINK -->
  <link name="link1">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.1"/>
      </geometry>
      <origin xyz="0.3 0 0"/>
      <material name="green"/>
    </visual>
  </link>

  <!-- ELBOW LINK -->
  <link name="link2">
    <visual>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
      <origin xyz="0.25 0 0"/>
      <material name="red"/>
    </visual>
  </link>

  <!-- END EFFECTOR -->
  <link name="link3">
    <visual>
      <geometry>
        <box size="0.3 0.1 0.1"/>
      </geometry>
      <origin xyz="0.15 0 0"/>
      <material name="green"/>
    </visual>
  </link>

  <!-- BASE ROTATION -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- SHOULDER -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.6 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <!-- ELBOW -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.5 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

</robot>
